---
const { portfolio } = Astro.props;
---

<section class="section">
  <h2 class="section-title">
    <span class="lang-es section-title-es">Proyectos Destacados</span>
    <span class="lang-en section-title-en">Featured Projects</span>
  </h2>

  <div class="portfolio-grid">
    {portfolio.map((project) => (
      <article class="portfolio-card">
        {project.image && (
          <div class="portfolio-card-image">
            <img src={project.image} alt={project.title.es} loading="lazy" />
          </div>
        )}
        <div class="portfolio-card-body">
          <h3 class="portfolio-card-title">
            <span class="lang-es">{project.title.es}</span>
            <span class="lang-en">{project.title.en}</span>
          </h3>
          <p class="portfolio-card-desc">
            <span class="lang-es">{project.description.es}</span>
            <span class="lang-en">{project.description.en}</span>
          </p>
        </div>
      </article>
    ))}
  </div>

  <p class="portfolio-footer">
    <span class="lang-es">
      Todos los proyectos están disponibles en mi portafolio en línea.
    </span>
    <span class="lang-en">
      All projects are available on my online portfolio.
    </span>
  </p>
</section>
