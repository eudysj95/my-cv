---
const { name, title, tagline, contact } = Astro.props;
---

<section class="hero">
  <div class="hero-photo">
    <img src="/perfil.jpg" alt={name} class="hero-img" width="150" height="150" />
  </div>

  <h1 class="hero-name">{name}</h1>
  <p class="hero-title">
    <span class="lang-es">{title.es}</span>
    <span class="lang-en">{title.en}</span>
  </p>
  <p class="hero-tagline">
    <span class="lang-es">{tagline.es}</span>
    <span class="lang-en">{tagline.en}</span>
  </p>

  <div class="hero-contact">
    <a href={`mailto:${contact.email}`} target="_blank" rel="noopener noreferrer">
      {contact.email}
    </a>
    <span class="lang-es">{contact.phone}</span>
    <span class="lang-en">{contact.phone}</span>
    <span>
      <span class="lang-es">{contact.location.es}</span>
      <span class="lang-en">{contact.location.en}</span>
    </span>
    {contact.linkedin && (
      <a href={contact.linkedin} target="_blank" rel="noopener noreferrer">
        LinkedIn
      </a>
    )}
    {contact.github && (
      <a href={contact.github} target="_blank" rel="noopener noreferrer">
        GitHub
      </a>
    )}
    {contact.portfolio && (
      <a href={contact.portfolio} target="_blank" rel="noopener noreferrer">
        <span class="lang-es">Portafolio</span>
        <span class="lang-en">Portfolio</span>
      </a>
    )}
  </div>
</section>
