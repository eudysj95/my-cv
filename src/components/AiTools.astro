---
const { aiTools } = Astro.props;
---

<section class="section">
  <h2 class="section-title">
    <span class="lang-es section-title-es">Herramientas de IA</span>
    <span class="lang-en section-title-en">AI Tools</span>
  </h2>

  {aiTools.map((group) => (
    <div class="skills-group">
      <h3 class="skills-group-title">
        <span class="lang-es">{group.category.es}</span>
        <span class="lang-en">{group.category.en}</span>
      </h3>
      <div class="skills-tags">
        {group.items.map((item) => (
          <span class="skill-tag">
            <span class="lang-es">{item.es}</span>
            <span class="lang-en">{item.en}</span>
          </span>
        ))}
      </div>
    </div>
  ))}
</section>
