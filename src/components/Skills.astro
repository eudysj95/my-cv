---
const { skills } = Astro.props;
---

<section class="section">
  <h2 class="section-title">
    <span class="lang-es section-title-es">Habilidades Técnicas</span>
    <span class="lang-en section-title-en">Technical Skills</span>
  </h2>

  {skills.map((group) => (
    <div class="skills-group">
      <h3 class="skills-group-title">
        <span class="lang-es">{group.category.es}</span>
        <span class="lang-en">{group.category.en}</span>
      </h3>
      <div class="skills-tags">
        {group.items.map((item) => (
          <span class="skill-tag">{item}</span>
        ))}
      </div>
    </div>
  ))}
</section>
