---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — Página no encontrada"
  description="La página que buscas no existe. Regresa al inicio."
  currentSlug=""
>
  <section class="page-404">
    <h1>404</h1>
    <p>
      <span class="lang-es">La página que buscas no existe.</span>
      <span class="lang-en">The page you are looking for does not exist.</span>
    </p>
    <a href="/">
      <span class="lang-es">Volver al inicio</span>
      <span class="lang-en">Back to home</span>
    </a>
  </section>
</BaseLayout>
