---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Skills from "../components/Skills.astro";
import AiTools from "../components/AiTools.astro";
import Experience from "../components/Experience.astro";
import Portfolio from "../components/Portfolio.astro";
import Education from "../components/Education.astro";
import PrintButton from "../components/PrintButton.astro";

import data from "../data/ia/es.json";
import dataEn from "../data/ia/en.json";
---

<BaseLayout
  title={`${data.name} — ${data.title.es}`}
  description={data.summary.es.substring(0, 160)}
  currentSlug="ia"
>
  <Hero
    name={data.name}
    title={data.title}
    tagline={data.tagline}
    contact={data.contact}
  />

  <PrintButton />

  <Skills skills={data.skills} />

  <AiTools aiTools={data.aiTools} />

  <Experience experience={data.experience} />

  <Portfolio portfolio={data.portfolio} />

  <Education education={data.education} />
</BaseLayout>
